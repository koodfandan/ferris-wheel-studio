APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///./data/hunyuan.db
REDIS_URL=redis://127.0.0.1:6379/0
STORAGE_MODE=local
LOCAL_STORAGE_ROOT=./data/storage
ENABLE_MOCK_PIPELINE=true
ENABLE_INLINE_WORKER=true
GENERATOR_PROVIDER=auto
HUNYUAN_DEVICE=cuda
HUNYUAN_SHAPE_MODEL=tencent/Hunyuan3D-2
HUNYUAN_TEXTURE_MODEL=tencent/Hunyuan3D-2
HUNYUAN_USE_LITE_SHAPE=false
HUNYUAN_USE_LITE_TEXTURE=false
HUNYUAN_REPO_PATH=
HUNYUAN_API_SERVER_BASE_URL=http://127.0.0.1:8080
HUNYUAN_API_SERVER_TIMEOUT_SECONDS=900
HUNYUAN_CLOUD_ENDPOINT=ai3d.tencentcloudapi.com
HUNYUAN_CLOUD_REGION=ap-guangzhou
HUNYUAN_CLOUD_VERSION=2025-05-13
HUNYUAN_CLOUD_SECRET_ID=
HUNYUAN_CLOUD_SECRET_KEY=
HUNYUAN_CLOUD_TOKEN=
HUNYUAN_CLOUD_QUALITY_MODE=pro
HUNYUAN_CLOUD_MODEL=3.0
HUNYUAN_CLOUD_POLL_INTERVAL_SECONDS=2.5
HUNYUAN_CLOUD_TIMEOUT_SECONDS=900
MESHY_API_BASE_URL=https://api.meshy.ai/openapi/v1
MESHY_API_KEY=
MESHY_AI_MODEL=latest
MESHY_MODEL_TYPE=standard
MESHY_ENABLE_PBR=false
MESHY_POLL_INTERVAL_SECONDS=5
MESHY_TIMEOUT_SECONDS=900
